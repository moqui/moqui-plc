

(*#-#-#-#-#-#-#-#-#-#---Declaration---#-#-#-#-#-#-#-#-#-#-#-#-#*)

{attribute 'no_assign'}
PROGRAM MqttParameterSub
VAR_EXTERNAL CONSTANT
	JSON_PAYLOAD_MAX_SIZE : UINT;
	(* Subscribe properties v5 *)
	subscriptionIdentifier : UDINT;
	(* subUserProperties : ARRAY [0..(MQTT.MQTTParam.g_udiMaxUserProperties - 1)] OF MQTT.MQTTStringPair; *)
	paramsSubQoS : MQTT.MQTT_QOS;
	paramsSubFilterMode : MQTT.FILTER_MODE;
	subNoLocalOption : BOOL;
	subRetainAsPublished : BOOL;
	subRetainHandling : MQTT.MQTT_RETAIN_HANDLING;
	liveParamsSubTopic : WSTRING(1024);
	liveParamsSubTimeout : UINT;
END_VAR
VAR_EXTERNAL
	paramsSubEnable : BOOL;
	connectionFactory : MqttConnectionFactory;
END_VAR
VAR
	done, busy, error : BOOL;
    errorId : INT;
	(* Subscriber *)
	subscriber : MQTT.MQTTSubscribe;
	(* Subscribe properties v5 *)
	mqttSubscribeProperties : MQTT.MQTTSubscribeProperties := (
		udiSubscriptionIdentifier := subscriptionIdentifier,
		xNoLocalOption := subNoLocalOption,
		xRetainAsPublished := subRetainAsPublished,
		eRetainHandling := subRetainHandling
		(* userProperties := subUserProperties; *)
	);
    (* JSON parser *)
    parser : DeserializeJsonToParameters;
	parserActive : BOOL; (* TRUE while parser is running across multiple cycles *)
	subTopicFilter : WSTRING(1024) := liveParamsSubTopic;
	(* Last incoming message *)
	lastSubMessage : STRING(JSON_PAYLOAD_MAX_SIZE);
    receivedPayload : WSTRING(JSON_PAYLOAD_MAX_SIZE);
	subscriberEnable : BOOL;
END_VAR


(*#-#-#-#-#-#-#-#-#-#---Implementation---#-#-#-#-#-#-#-#-#-#-#-#-#*)

(* Subscription disabled *)
IF NOT paramsSubEnable THEN
	done := FALSE; busy := FALSE; error := FALSE; errorId := 0;
    RETURN;
END_IF;

(* Connect to the broker *)
connectionFactory(connect := TRUE, error => error, errorId => errorId);
(* Reset and retry on next cycle *)
IF connectionFactory.connection.xError THEN
	connectionFactory(connect := FALSE, error => error, errorId => errorId);
	done := FALSE; busy := FALSE;
	RETURN;
END_IF;

(* Manage subscriber enable: disable for one cycle on error to reset the FB *)
IF subscriber.xError THEN
	subscriberEnable := FALSE;
ELSE
	subscriberEnable := connectionFactory.connected;
END_IF;

(* Drive subscriber continuously; xDone = subscription confirmed (sub ack), not end of session *)
subscriber(xEnable := subscriberEnable, mqttClient := connectionFactory.connection,
	eFilterMode := paramsSubFilterMode, wsTopicFilter := subTopicFilter, eSubscribeQoS := paramsSubQoS,
	udiTimeout := liveParamsSubTimeout, pbPayload := ADR(lastSubMessage),
	udiMaxPayloadSize := SIZEOF(lastSubMessage), mQTTSubscribeProperties := mqttSubscribeProperties,
	xDone => done, xBusy => busy, xError => error, eMQTTError => errorId);

(* xReceived pulses TRUE for one cycle only: latch parserActive to keep parser running *)
IF subscriber.xSubscribeActive AND subscriber.xReceived
		AND subscriber.wsLastTopic = subTopicFilter THEN
	receivedPayload := TO_WSTRING(lastSubMessage);
	parserActive := TRUE;
END_IF;

(* Drive parser every cycle until done/error, regardless of xReceived *)
IF parserActive THEN
	(* JSON parsing *)
	parser(execute := TRUE, jsonPayload := receivedPayload,
		busy => busy, error => error, errorId => errorId);

	IF parser.done OR parser.error THEN
		(* Auto reset: next cycle restarts from scratch *)
		parser(execute := FALSE, done => done, busy => busy,
			error => error, errorId => errorId);
		parserActive := FALSE;
	END_IF;
END_IF;
