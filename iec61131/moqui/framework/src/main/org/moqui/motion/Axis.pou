                            AxisCmd.GearIn : gearInExecute := FALSE;
                            AxisCmd.GearInPos : gearInPosExecute := FALSE;
                            AxisCmd.CamIn : camInExecute := FALSE;
                            AxisCmd.Phasing : phasingExecute := FALSE;
                            AxisCmd.SetPosition : setPositionExecute := FALSE;
                            AxisCmd.PositionProfile : posProfileExecute := FALSE;
                            AxisCmd.VelocityProfile : velProfileExecute := FALSE;
                            AxisCmd.AccelerationProfile: accProfileExecute := FALSE;
                        END_CASE;

                        hasPending := FALSE;
                    END_IF;

                    commandAborted := TRUE;
                    internalStatus := AxisInternalStatus.Ready;
                ELSE
                    pendingCmd := cmd;
                    pendingOldPosition := position; pendingOldDistance := distance; pendingOldVelocity := velocity;
                    pendingOldRatioNumerator := ratioNumerator; pendingOldRatioDenominator := ratioDenominator;
                    pendingOldCamVersion := camVersion; pendingOldStartMode := startMode;
                    pendingOldMasterOffset := masterOffset; pendingOldSlaveOffset := slaveOffset;
                    hasPending := TRUE;
                    oldCmd := pendingCmd;

                    CASE pendingCmd OF
                        AxisCmd.MoveVelocity : moveVelocityExecute := TRUE;
                        AxisCmd.MoveAbsolute : moveAbsoluteExecute := TRUE;
                        AxisCmd.MoveRelative : moveRelativeExecute := TRUE;
                        AxisCmd.MoveAdditive : moveAdditiveExecute := TRUE;
                        AxisCmd.MoveSuperimposed : moveSuperimposedExecute := TRUE;
                        AxisCmd.Halt : haltExecute := TRUE;
                        AxisCmd.GearIn : gearInExecute := TRUE;
                        AxisCmd.GearInPos : gearInPosExecute := TRUE;
                        AxisCmd.CamIn : camInExecute := TRUE;
                        AxisCmd.Phasing : phasingExecute := TRUE;
                        AxisCmd.SetPosition : setPositionExecute := TRUE;
                        AxisCmd.PositionProfile : posProfileExecute := TRUE;
                        AxisCmd.VelocityProfile : velProfileExecute := TRUE;
                        AxisCmd.AccelerationProfile: accProfileExecute := TRUE;
                    ELSE
						hasPending := FALSE;
						commandAborted := TRUE;
						internalStatus := AxisInternalStatus.Ready;
                    END_CASE;
                END_IF;
            END_IF;

        AxisInternalStatus.CheckAdditiveState :
            IF cmd <> oldCmd THEN
                commandExecuted := FALSE;
                internalStatus := AxisInternalStatus.Ready;
            ELSIF distance <> oldDistance THEN
                oldDistance := distance;
                moveAdditiveExecute := TRUE;
                commandExecuted := FALSE;
                internalStatus := AxisInternalStatus.MoveAdditiveState;
            END_IF;

        (* MoveSuperimposed *)
        AxisInternalStatus.MoveSuperimposedState :
            IF moveSuperimposed.Done THEN
                moveSuperimposedExecute := FALSE;
                IF hasPending THEN
                    hasPending := FALSE;
                    oldPosition := pendingOldPosition; oldDistance := pendingOldDistance; oldVelocity := pendingOldVelocity;
                    oldRatioNumerator := pendingOldRatioNumerator; oldRatioDenominator := pendingOldRatioDenominator;
                    oldCamVersion := pendingOldCamVersion; oldStartMode := pendingOldStartMode;
                    oldMasterOffset := pendingOldMasterOffset; oldSlaveOffset := pendingOldSlaveOffset;
                    commandExecuted := FALSE; commandAborted := FALSE;

                    CASE oldCmd OF
                        AxisCmd.MoveVelocity : internalStatus := AxisInternalStatus.MoveVelocityState;
                        AxisCmd.MoveAbsolute : internalStatus := AxisInternalStatus.MoveAbsoluteState;
                        AxisCmd.MoveRelative : internalStatus := AxisInternalStatus.MoveRelativeState;
                        AxisCmd.MoveAdditive : internalStatus := AxisInternalStatus.MoveAdditiveState;
                        AxisCmd.MoveSuperimposed : internalStatus := AxisInternalStatus.MoveSuperimposedState;
