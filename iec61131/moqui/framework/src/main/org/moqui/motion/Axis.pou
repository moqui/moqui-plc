            IF cmd <> oldCmd THEN
                IF bufferMode = SM3_Basic.MC_BUFFER_MODE.aborting OR hasPending THEN
                    moveSuperimposedExecute := FALSE;
                    IF hasPending THEN
                        CASE pendingCmd OF
                            AxisCmd.MoveVelocity : moveVelocityExecute := FALSE;
                            AxisCmd.MoveAbsolute : moveAbsoluteExecute := FALSE;
                            AxisCmd.MoveRelative : moveRelativeExecute := FALSE;
                            AxisCmd.MoveAdditive : moveAdditiveExecute := FALSE;
                            AxisCmd.MoveSuperimposed : moveSuperimposedExecute := FALSE;
