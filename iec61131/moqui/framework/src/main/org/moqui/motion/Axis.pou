        AxisInternalStatus.CheckSuperimposedState :
            IF cmd <> oldCmd THEN
                commandExecuted := FALSE;
                internalStatus := AxisInternalStatus.Ready;
            ELSIF distance <> oldDistance THEN
                oldDistance := distance;
                moveSuperimposedExecute := TRUE;
                commandExecuted := FALSE;
                internalStatus := AxisInternalStatus.MoveSuperimposedState;
            END_IF;

        (* GearInState / CheckGearState *)
        AxisInternalStatus.GearInState :
            IF gearIn.InGear THEN
                gearInExecute := FALSE;
                commandExecuted := TRUE;
                internalStatus := AxisInternalStatus.CheckGearState;
            END_IF;

            IF cmd <> oldCmd THEN
                gearInExecute := FALSE;
                gearOutExecute := TRUE; (* Explicit disengagement before command change *)
                commandAborted := TRUE;
                internalStatus := AxisInternalStatus.GearOutState;
            END_IF;

        AxisInternalStatus.CheckGearState :
            IF cmd <> oldCmd THEN
                commandExecuted := FALSE;
                gearOutExecute := TRUE;
                internalStatus := AxisInternalStatus.GearOutState;
            ELSIF (ratioNumerator <> oldRatioNumerator) OR (ratioDenominator <> oldRatioDenominator) THEN
                oldRatioNumerator := ratioNumerator;
                oldRatioDenominator := ratioDenominator;
                gearInExecute := TRUE;
                commandExecuted := FALSE;
                internalStatus := AxisInternalStatus.GearInState;
            END_IF;

        (* GearOut - disengage gear synchronization *)
        AxisInternalStatus.GearOutState :
            IF gearOut.Done THEN
                gearOutExecute := FALSE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;

        (* GearInPos (positional synchronization) *)
        AxisInternalStatus.GearInPosState :
            IF gearInPos.InSync THEN
                gearInPosExecute := FALSE;
                commandExecuted := TRUE;
                internalStatus := AxisInternalStatus.CheckGearInPosState;
            END_IF;

            IF cmd <> oldCmd THEN
                gearInPosExecute := FALSE;
                gearOutExecute := TRUE;
                commandAborted := TRUE;
                internalStatus := AxisInternalStatus.GearOutState;
            END_IF;

        AxisInternalStatus.CheckGearInPosState :
            IF cmd <> oldCmd THEN
                commandExecuted := FALSE;
                gearOutExecute := TRUE;
                internalStatus := AxisInternalStatus.GearOutState;
            ELSIF (ratioNumerator <> oldRatioNumerator) OR (ratioDenominator <> oldRatioDenominator) THEN
                oldRatioNumerator := ratioNumerator;
                oldRatioDenominator := ratioDenominator;
                gearInPosExecute := TRUE;
                commandExecuted := FALSE;
                internalStatus := AxisInternalStatus.GearInPosState;
            END_IF;

        (* CamInState / CheckCamState *)
        AxisInternalStatus.CamInState :
            IF camIn.InSync THEN
                camInExecute := FALSE;
                commandExecuted := TRUE;
                internalStatus := AxisInternalStatus.CheckCamState;
            END_IF;

            IF cmd <> oldCmd THEN
                camInExecute := FALSE;
                camOutExecute := TRUE; (* Explicit disengagement before command change *)
                commandAborted := TRUE;
                internalStatus := AxisInternalStatus.CamOutState;
            END_IF;

        AxisInternalStatus.CheckCamState :
            IF cmd <> oldCmd THEN
                commandExecuted := FALSE;
                camOutExecute := TRUE;
                internalStatus := AxisInternalStatus.CamOutState;
            ELSIF (camVersion <> oldCamVersion) OR (startMode <> oldStartMode) OR
                    (masterOffset <> oldMasterOffset) OR (slaveOffset <> oldSlaveOffset) THEN
                oldCamVersion := camVersion;
                oldStartMode := startMode;
                oldMasterOffset := masterOffset;
                oldSlaveOffset := slaveOffset;
                camInExecute := TRUE;
                commandExecuted := FALSE;
                internalStatus := AxisInternalStatus.CamInState;
            END_IF;

        (* CamOut - disengage CAM synchronization *)
        AxisInternalStatus.CamOutState :
            IF camOut.Done THEN
                camOutExecute := FALSE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;

        (* Phasing - shift slave phase while in sync *)
        AxisInternalStatus.PhasingState :
            IF phasing.Done THEN
                phasingExecute := FALSE;
                IF hasPending THEN
                    hasPending := FALSE;
                    oldPosition := pendingOldPosition; oldDistance := pendingOldDistance; oldVelocity := pendingOldVelocity;
                    oldRatioNumerator := pendingOldRatioNumerator; oldRatioDenominator := pendingOldRatioDenominator;
                    oldCamVersion := pendingOldCamVersion; oldStartMode := pendingOldStartMode;
                    oldMasterOffset := pendingOldMasterOffset; oldSlaveOffset := pendingOldSlaveOffset;
                    commandExecuted := FALSE; commandAborted := FALSE;

                    CASE oldCmd OF
                        AxisCmd.MoveVelocity : internalStatus := AxisInternalStatus.MoveVelocityState;
                        AxisCmd.MoveAbsolute : internalStatus := AxisInternalStatus.MoveAbsoluteState;
                        AxisCmd.MoveRelative : internalStatus := AxisInternalStatus.MoveRelativeState;
                        AxisCmd.MoveAdditive : internalStatus := AxisInternalStatus.MoveAdditiveState;
                        AxisCmd.MoveSuperimposed : internalStatus := AxisInternalStatus.MoveSuperimposedState;
                        AxisCmd.Halt : internalStatus := AxisInternalStatus.HaltState;
                        AxisCmd.GearIn : internalStatus := AxisInternalStatus.GearInState;
                        AxisCmd.GearInPos : internalStatus := AxisInternalStatus.GearInPosState;
                        AxisCmd.CamIn : internalStatus := AxisInternalStatus.CamInState;
                        AxisCmd.Phasing : internalStatus := AxisInternalStatus.PhasingState;
                        AxisCmd.SetPosition : internalStatus := AxisInternalStatus.SetPositionState;
                        AxisCmd.PositionProfile : internalStatus := AxisInternalStatus.PositionProfileState;
                        AxisCmd.VelocityProfile : internalStatus := AxisInternalStatus.VelocityProfileState;
                        AxisCmd.AccelerationProfile: internalStatus := AxisInternalStatus.AccelerationProfileState;
                    ELSE
						internalStatus := AxisInternalStatus.Ready;
                    END_CASE;
                ELSE
                    commandExecuted := TRUE;
                    internalStatus := AxisInternalStatus.Ready;
                END_IF;
            END_IF;

            IF cmd <> oldCmd THEN
                IF bufferMode = SM3_Basic.MC_BUFFER_MODE.aborting OR hasPending THEN
                    phasingExecute := FALSE;
                    IF hasPending THEN
                        CASE pendingCmd OF
                            AxisCmd.MoveVelocity : moveVelocityExecute := FALSE;
                            AxisCmd.MoveAbsolute : moveAbsoluteExecute := FALSE;
                            AxisCmd.MoveRelative : moveRelativeExecute := FALSE;
                            AxisCmd.MoveAdditive : moveAdditiveExecute := FALSE;
                            AxisCmd.MoveSuperimposed : moveSuperimposedExecute := FALSE;
                            AxisCmd.Halt : haltExecute := FALSE;
                            AxisCmd.GearIn : gearInExecute := FALSE;
                            AxisCmd.GearInPos : gearInPosExecute := FALSE;
                            AxisCmd.CamIn : camInExecute := FALSE;
                            AxisCmd.Phasing : phasingExecute := FALSE;
                            AxisCmd.SetPosition : setPositionExecute := FALSE;
                            AxisCmd.PositionProfile : posProfileExecute := FALSE;
                            AxisCmd.VelocityProfile : velProfileExecute := FALSE;
                            AxisCmd.AccelerationProfile: accProfileExecute := FALSE;
                        END_CASE;

                        hasPending := FALSE;
                    END_IF;

                    commandAborted := TRUE;
                    internalStatus := AxisInternalStatus.Ready;
                ELSE
                    pendingCmd := cmd;
                    pendingOldPosition := position; pendingOldDistance := distance; pendingOldVelocity := velocity;
                    pendingOldRatioNumerator := ratioNumerator; pendingOldRatioDenominator := ratioDenominator;
                    pendingOldCamVersion := camVersion; pendingOldStartMode := startMode;
                    pendingOldMasterOffset := masterOffset; pendingOldSlaveOffset := slaveOffset;
                    hasPending := TRUE;
                    oldCmd := pendingCmd;

                    CASE pendingCmd OF
                        AxisCmd.MoveVelocity : moveVelocityExecute := TRUE;
                        AxisCmd.MoveAbsolute : moveAbsoluteExecute := TRUE;
                        AxisCmd.MoveRelative : moveRelativeExecute := TRUE;
                        AxisCmd.MoveAdditive : moveAdditiveExecute := TRUE;
                        AxisCmd.MoveSuperimposed : moveSuperimposedExecute := TRUE;
                        AxisCmd.Halt : haltExecute := TRUE;
                        AxisCmd.GearIn : gearInExecute := TRUE;
                        AxisCmd.GearInPos : gearInPosExecute := TRUE;
                        AxisCmd.CamIn : camInExecute := TRUE;
                        AxisCmd.Phasing : phasingExecute := TRUE;
                        AxisCmd.SetPosition : setPositionExecute := TRUE;
                        AxisCmd.PositionProfile : posProfileExecute := TRUE;
                        AxisCmd.VelocityProfile : velProfileExecute := TRUE;
                        AxisCmd.AccelerationProfile: accProfileExecute := TRUE;
                    ELSE
						hasPending := FALSE;
						commandAborted := TRUE;
						internalStatus := AxisInternalStatus.Ready;
                    END_CASE;
                END_IF;
            END_IF;

        (* Jog - manual jog (level-triggered: jogForward/jogBackward) *)
        AxisInternalStatus.JogState :
            IF cmd <> oldCmd THEN
                commandAborted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;

        (* Halt - decelerate to standstill *)
        AxisInternalStatus.HaltState :
            IF halt.Done THEN
                haltExecute := FALSE;
                IF NOT axisEnable THEN
                    (* Power withdrawn - discard any pending command *)
                    IF hasPending THEN
                        CASE pendingCmd OF
                            AxisCmd.MoveVelocity : moveVelocityExecute := FALSE;
                            AxisCmd.MoveAbsolute : moveAbsoluteExecute := FALSE;
                            AxisCmd.MoveRelative : moveRelativeExecute := FALSE;
                            AxisCmd.MoveAdditive : moveAdditiveExecute := FALSE;
                            AxisCmd.MoveSuperimposed : moveSuperimposedExecute := FALSE;
                            AxisCmd.Halt : haltExecute := FALSE;
                            AxisCmd.GearIn : gearInExecute := FALSE;
                            AxisCmd.GearInPos : gearInPosExecute := FALSE;
                            AxisCmd.CamIn : camInExecute := FALSE;
                            AxisCmd.Phasing : phasingExecute := FALSE;
                            AxisCmd.SetPosition : setPositionExecute := FALSE;
                            AxisCmd.PositionProfile : posProfileExecute := FALSE;
                            AxisCmd.VelocityProfile : velProfileExecute := FALSE;
                            AxisCmd.AccelerationProfile: accProfileExecute := FALSE;
                        END_CASE;

                        hasPending := FALSE;
                    END_IF;
  
	                powerEnable := FALSE;
                    internalStatus := AxisInternalStatus.NotPowered;
                ELSIF hasPending THEN
                    hasPending := FALSE;
                    oldPosition := pendingOldPosition; oldDistance := pendingOldDistance; oldVelocity := pendingOldVelocity;
                    oldRatioNumerator := pendingOldRatioNumerator; oldRatioDenominator := pendingOldRatioDenominator;
                    oldCamVersion := pendingOldCamVersion; oldStartMode := pendingOldStartMode;
                    oldMasterOffset := pendingOldMasterOffset; oldSlaveOffset := pendingOldSlaveOffset;
                    commandExecuted := FALSE; commandAborted := FALSE;

                    CASE oldCmd OF
                        AxisCmd.MoveVelocity : internalStatus := AxisInternalStatus.MoveVelocityState;
                        AxisCmd.MoveAbsolute : internalStatus := AxisInternalStatus.MoveAbsoluteState;
                        AxisCmd.MoveRelative : internalStatus := AxisInternalStatus.MoveRelativeState;
                        AxisCmd.MoveAdditive : internalStatus := AxisInternalStatus.MoveAdditiveState;
                        AxisCmd.MoveSuperimposed : internalStatus := AxisInternalStatus.MoveSuperimposedState;
                        AxisCmd.Halt : internalStatus := AxisInternalStatus.HaltState;
                        AxisCmd.GearIn : internalStatus := AxisInternalStatus.GearInState;
                        AxisCmd.GearInPos : internalStatus := AxisInternalStatus.GearInPosState;
                        AxisCmd.CamIn : internalStatus := AxisInternalStatus.CamInState;
                        AxisCmd.Phasing : internalStatus := AxisInternalStatus.PhasingState;
                        AxisCmd.SetPosition : internalStatus := AxisInternalStatus.SetPositionState;
                        AxisCmd.PositionProfile : internalStatus := AxisInternalStatus.PositionProfileState;
                        AxisCmd.VelocityProfile : internalStatus := AxisInternalStatus.VelocityProfileState;
                        AxisCmd.AccelerationProfile: internalStatus := AxisInternalStatus.AccelerationProfileState;
                    ELSE
                    	internalStatus := AxisInternalStatus.Ready;
                    END_CASE;
                ELSE
                    commandExecuted := TRUE;
                    internalStatus := AxisInternalStatus.Ready;
                END_IF;
            END_IF;
            IF cmd <> oldCmd THEN
                IF bufferMode = SM3_Basic.MC_BUFFER_MODE.aborting OR hasPending THEN
                    haltExecute := FALSE;
                    IF hasPending THEN
                        CASE pendingCmd OF
                            AxisCmd.MoveVelocity : moveVelocityExecute := FALSE;
                            AxisCmd.MoveAbsolute : moveAbsoluteExecute := FALSE;
                            AxisCmd.MoveRelative : moveRelativeExecute := FALSE;
                            AxisCmd.MoveAdditive : moveAdditiveExecute := FALSE;
                            AxisCmd.MoveSuperimposed : moveSuperimposedExecute := FALSE;
                            AxisCmd.Halt : haltExecute := FALSE;
                            AxisCmd.GearIn : gearInExecute := FALSE;
                            AxisCmd.GearInPos : gearInPosExecute := FALSE;
                            AxisCmd.CamIn : camInExecute := FALSE;
                            AxisCmd.Phasing : phasingExecute := FALSE;
                            AxisCmd.SetPosition : setPositionExecute := FALSE;
                            AxisCmd.PositionProfile : posProfileExecute := FALSE;
                            AxisCmd.VelocityProfile : velProfileExecute := FALSE;
                            AxisCmd.AccelerationProfile: accProfileExecute := FALSE;
                        END_CASE;

                        hasPending := FALSE;
                    END_IF;

                    commandAborted := TRUE;
                    internalStatus := AxisInternalStatus.Ready;
                ELSE
                    pendingCmd := cmd;
                    pendingOldPosition := position; pendingOldDistance := distance; pendingOldVelocity := velocity;
                    pendingOldRatioNumerator := ratioNumerator; pendingOldRatioDenominator := ratioDenominator;
                    pendingOldCamVersion := camVersion; pendingOldStartMode := startMode;
                    pendingOldMasterOffset := masterOffset; pendingOldSlaveOffset := slaveOffset;
                    hasPending := TRUE;
                    oldCmd := pendingCmd;

                    CASE pendingCmd OF
                        AxisCmd.MoveVelocity : moveVelocityExecute := TRUE;
                        AxisCmd.MoveAbsolute : moveAbsoluteExecute := TRUE;
                        AxisCmd.MoveRelative : moveRelativeExecute := TRUE;
                        AxisCmd.MoveAdditive : moveAdditiveExecute := TRUE;
                        AxisCmd.MoveSuperimposed : moveSuperimposedExecute := TRUE;
                        AxisCmd.Halt : haltExecute := TRUE;
                        AxisCmd.GearIn : gearInExecute := TRUE;
                        AxisCmd.GearInPos : gearInPosExecute := TRUE;
                        AxisCmd.CamIn : camInExecute := TRUE;
                        AxisCmd.Phasing : phasingExecute := TRUE;
                        AxisCmd.SetPosition : setPositionExecute := TRUE;
                        AxisCmd.PositionProfile : posProfileExecute := TRUE;
                        AxisCmd.VelocityProfile : velProfileExecute := TRUE;
                        AxisCmd.AccelerationProfile: accProfileExecute := TRUE;
                    ELSE
                    	hasPending := FALSE;
                        commandAborted := TRUE;
                        internalStatus := AxisInternalStatus.Ready;
                    END_CASE;
                END_IF;
            END_IF;

        (* HaltSuperimposed - halt only the superimposed motion *)
        AxisInternalStatus.HaltSuperimposedState :
            IF haltSuperimposed.Done THEN
                haltSuperimposedExecute := FALSE;
                commandExecuted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;
            IF cmd <> oldCmd THEN
                haltSuperimposedExecute := FALSE;
                commandAborted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;

        (* Stopping - PLCopen Stopping state.
         * MC_Stop decelerates to standstill; Execute must remain TRUE while in Stopping.
         * Setting Execute := FALSE after Done returns the axis to Standstill. *)
        AxisInternalStatus.StoppingState :
            IF stop.Done THEN
                stopExecute := FALSE; (* Dropping Execute releases MC_Stop and returns axis to Standstill *)
                commandExecuted := TRUE;
                IF NOT axisEnable THEN
                    powerEnable := FALSE;
                    internalStatus := AxisInternalStatus.NotPowered;
                ELSE
                    internalStatus := AxisInternalStatus.Ready;
                END_IF;
            END_IF;

        (* SetPosition - shift coordinate system without motion *)
        AxisInternalStatus.SetPositionState :
            IF setPosition.Done THEN
                setPositionExecute := FALSE;
                IF hasPending THEN
                    hasPending := FALSE;
                    oldPosition := pendingOldPosition; oldDistance := pendingOldDistance; oldVelocity := pendingOldVelocity;
                    oldRatioNumerator := pendingOldRatioNumerator; oldRatioDenominator := pendingOldRatioDenominator;
                    oldCamVersion := pendingOldCamVersion; oldStartMode := pendingOldStartMode;
                    oldMasterOffset := pendingOldMasterOffset; oldSlaveOffset := pendingOldSlaveOffset;
                    commandExecuted := FALSE; commandAborted := FALSE;

                    CASE oldCmd OF
                        AxisCmd.MoveVelocity : internalStatus := AxisInternalStatus.MoveVelocityState;
                        AxisCmd.MoveAbsolute : internalStatus := AxisInternalStatus.MoveAbsoluteState;
                        AxisCmd.MoveRelative : internalStatus := AxisInternalStatus.MoveRelativeState;
                        AxisCmd.MoveAdditive : internalStatus := AxisInternalStatus.MoveAdditiveState;
                        AxisCmd.MoveSuperimposed : internalStatus := AxisInternalStatus.MoveSuperimposedState;
                        AxisCmd.Halt : internalStatus := AxisInternalStatus.HaltState;
                        AxisCmd.GearIn : internalStatus := AxisInternalStatus.GearInState;
                        AxisCmd.GearInPos : internalStatus := AxisInternalStatus.GearInPosState;
                        AxisCmd.CamIn : internalStatus := AxisInternalStatus.CamInState;
                        AxisCmd.Phasing : internalStatus := AxisInternalStatus.PhasingState;
                        AxisCmd.SetPosition : internalStatus := AxisInternalStatus.SetPositionState;
                        AxisCmd.PositionProfile : internalStatus := AxisInternalStatus.PositionProfileState;
                        AxisCmd.VelocityProfile : internalStatus := AxisInternalStatus.VelocityProfileState;
                        AxisCmd.AccelerationProfile: internalStatus := AxisInternalStatus.AccelerationProfileState;
                    ELSE
                        internalStatus := AxisInternalStatus.Ready;
                    END_CASE;
                ELSE
                    commandExecuted := TRUE;
                    internalStatus := AxisInternalStatus.Ready;
                END_IF;
            END_IF;
            IF cmd <> oldCmd THEN
                IF bufferMode = SM3_Basic.MC_BUFFER_MODE.aborting OR hasPending THEN
                    setPositionExecute := FALSE;
                    IF hasPending THEN
                        CASE pendingCmd OF
                            AxisCmd.MoveVelocity : moveVelocityExecute := FALSE;
                            AxisCmd.MoveAbsolute : moveAbsoluteExecute := FALSE;
                            AxisCmd.MoveRelative : moveRelativeExecute := FALSE;
                            AxisCmd.MoveAdditive : moveAdditiveExecute := FALSE;
                            AxisCmd.MoveSuperimposed : moveSuperimposedExecute := FALSE;
                            AxisCmd.Halt : haltExecute := FALSE;
                            AxisCmd.GearIn : gearInExecute := FALSE;
                            AxisCmd.GearInPos : gearInPosExecute := FALSE;
                            AxisCmd.CamIn : camInExecute := FALSE;
                            AxisCmd.Phasing : phasingExecute := FALSE;
                            AxisCmd.SetPosition : setPositionExecute := FALSE;
                            AxisCmd.PositionProfile : posProfileExecute := FALSE;
                            AxisCmd.VelocityProfile : velProfileExecute := FALSE;
                            AxisCmd.AccelerationProfile: accProfileExecute := FALSE;
                        END_CASE;

                        hasPending := FALSE;
                    END_IF;

                    commandAborted := TRUE;
                    internalStatus := AxisInternalStatus.Ready;
                ELSE
                    pendingCmd := cmd;
                    pendingOldPosition := position; pendingOldDistance := distance; pendingOldVelocity := velocity;
                    pendingOldRatioNumerator := ratioNumerator; pendingOldRatioDenominator := ratioDenominator;
                    pendingOldCamVersion := camVersion; pendingOldStartMode := startMode;
                    pendingOldMasterOffset := masterOffset; pendingOldSlaveOffset := slaveOffset;
                    hasPending := TRUE;
                    oldCmd := pendingCmd;

                    CASE pendingCmd OF
                        AxisCmd.MoveVelocity : moveVelocityExecute := TRUE;
                        AxisCmd.MoveAbsolute : moveAbsoluteExecute := TRUE;
                        AxisCmd.MoveRelative : moveRelativeExecute := TRUE;
                        AxisCmd.MoveAdditive : moveAdditiveExecute := TRUE;
                        AxisCmd.MoveSuperimposed : moveSuperimposedExecute := TRUE;
                        AxisCmd.Halt : haltExecute := TRUE;
                        AxisCmd.GearIn : gearInExecute := TRUE;
                        AxisCmd.GearInPos : gearInPosExecute := TRUE;
                        AxisCmd.CamIn : camInExecute := TRUE;
                        AxisCmd.Phasing : phasingExecute := TRUE;
                        AxisCmd.SetPosition : setPositionExecute := TRUE;
                        AxisCmd.PositionProfile : posProfileExecute := TRUE;
                        AxisCmd.VelocityProfile : velProfileExecute := TRUE;
                        AxisCmd.AccelerationProfile: accProfileExecute := TRUE;
                    ELSE
						hasPending := FALSE;
						commandAborted := TRUE;
						internalStatus := AxisInternalStatus.Ready;
                    END_CASE;
                END_IF;
            END_IF;

        (* PositionProfile *)
        AxisInternalStatus.PositionProfileState :
            IF mcPositionProfile.Done THEN
                posProfileExecute := FALSE;
                IF hasPending THEN
                    hasPending := FALSE;
                    oldPosition := pendingOldPosition; oldDistance := pendingOldDistance; oldVelocity := pendingOldVelocity;
                    oldRatioNumerator := pendingOldRatioNumerator; oldRatioDenominator := pendingOldRatioDenominator;
                    oldCamVersion := pendingOldCamVersion; oldStartMode := pendingOldStartMode;
                    oldMasterOffset := pendingOldMasterOffset; oldSlaveOffset := pendingOldSlaveOffset;
                    commandExecuted := FALSE; commandAborted := FALSE;

                    CASE oldCmd OF
                        AxisCmd.MoveVelocity : internalStatus := AxisInternalStatus.MoveVelocityState;
                        AxisCmd.MoveAbsolute : internalStatus := AxisInternalStatus.MoveAbsoluteState;
                        AxisCmd.MoveRelative : internalStatus := AxisInternalStatus.MoveRelativeState;
                        AxisCmd.MoveAdditive : internalStatus := AxisInternalStatus.MoveAdditiveState;
                        AxisCmd.MoveSuperimposed : internalStatus := AxisInternalStatus.MoveSuperimposedState;
                        AxisCmd.Halt : internalStatus := AxisInternalStatus.HaltState;
                        AxisCmd.GearIn : internalStatus := AxisInternalStatus.GearInState;
                        AxisCmd.GearInPos : internalStatus := AxisInternalStatus.GearInPosState;
                        AxisCmd.CamIn : internalStatus := AxisInternalStatus.CamInState;
                        AxisCmd.Phasing : internalStatus := AxisInternalStatus.PhasingState;
                        AxisCmd.SetPosition : internalStatus := AxisInternalStatus.SetPositionState;
                        AxisCmd.PositionProfile : internalStatus := AxisInternalStatus.PositionProfileState;
                        AxisCmd.VelocityProfile : internalStatus := AxisInternalStatus.VelocityProfileState;
                        AxisCmd.AccelerationProfile: internalStatus := AxisInternalStatus.AccelerationProfileState;
                    ELSE
                        internalStatus := AxisInternalStatus.Ready;
                    END_CASE;
                ELSE
                    commandExecuted := TRUE;
                    internalStatus := AxisInternalStatus.Ready;
                END_IF;
            END_IF;
            IF cmd <> oldCmd THEN
                IF bufferMode = SM3_Basic.MC_BUFFER_MODE.aborting OR hasPending THEN
                    posProfileExecute := FALSE;
                    IF hasPending THEN
                        CASE pendingCmd OF
                            AxisCmd.MoveVelocity : moveVelocityExecute := FALSE;
                            AxisCmd.MoveAbsolute : moveAbsoluteExecute := FALSE;
                            AxisCmd.MoveRelative : moveRelativeExecute := FALSE;
                            AxisCmd.MoveAdditive : moveAdditiveExecute := FALSE;
                            AxisCmd.MoveSuperimposed : moveSuperimposedExecute := FALSE;
                            AxisCmd.Halt : haltExecute := FALSE;
                            AxisCmd.GearIn : gearInExecute := FALSE;
                            AxisCmd.GearInPos : gearInPosExecute := FALSE;
                            AxisCmd.CamIn : camInExecute := FALSE;
                            AxisCmd.Phasing : phasingExecute := FALSE;
                            AxisCmd.SetPosition : setPositionExecute := FALSE;
                            AxisCmd.PositionProfile : posProfileExecute := FALSE;
                            AxisCmd.VelocityProfile : velProfileExecute := FALSE;
                            AxisCmd.AccelerationProfile: accProfileExecute := FALSE;
                        END_CASE;

                        hasPending := FALSE;
                    END_IF;

                    commandAborted := TRUE;
                    internalStatus := AxisInternalStatus.Ready;
                ELSE
                    pendingCmd := cmd;
                    pendingOldPosition := position; pendingOldDistance := distance; pendingOldVelocity := velocity;
                    pendingOldRatioNumerator := ratioNumerator; pendingOldRatioDenominator := ratioDenominator;
                    pendingOldCamVersion := camVersion; pendingOldStartMode := startMode;
                    pendingOldMasterOffset := masterOffset; pendingOldSlaveOffset := slaveOffset;
                    hasPending := TRUE;
                    oldCmd := pendingCmd;

                    CASE pendingCmd OF
                        AxisCmd.MoveVelocity : moveVelocityExecute := TRUE;
                        AxisCmd.MoveAbsolute : moveAbsoluteExecute := TRUE;
                        AxisCmd.MoveRelative : moveRelativeExecute := TRUE;
                        AxisCmd.MoveAdditive : moveAdditiveExecute := TRUE;
                        AxisCmd.MoveSuperimposed : moveSuperimposedExecute := TRUE;
                        AxisCmd.Halt : haltExecute := TRUE;
                        AxisCmd.GearIn : gearInExecute := TRUE;
                        AxisCmd.GearInPos : gearInPosExecute := TRUE;
                        AxisCmd.CamIn : camInExecute := TRUE;
                        AxisCmd.Phasing : phasingExecute := TRUE;
                        AxisCmd.SetPosition : setPositionExecute := TRUE;
                        AxisCmd.PositionProfile : posProfileExecute := TRUE;
                        AxisCmd.VelocityProfile : velProfileExecute := TRUE;
                        AxisCmd.AccelerationProfile: accProfileExecute := TRUE;
					ELSE
						hasPending := FALSE;
						commandAborted := TRUE;
						internalStatus := AxisInternalStatus.Ready;
                    END_CASE;
                END_IF;
            END_IF;

        (* VelocityProfile *)
        AxisInternalStatus.VelocityProfileState :
            IF mcVelocityProfile.Done THEN
                velProfileExecute := FALSE;
                IF hasPending THEN
                    hasPending := FALSE;
                    oldPosition := pendingOldPosition; oldDistance := pendingOldDistance; oldVelocity := pendingOldVelocity;
                    oldRatioNumerator := pendingOldRatioNumerator; oldRatioDenominator := pendingOldRatioDenominator;
                    oldCamVersion := pendingOldCamVersion; oldStartMode := pendingOldStartMode;
                    oldMasterOffset := pendingOldMasterOffset; oldSlaveOffset := pendingOldSlaveOffset;
                    commandExecuted := FALSE; commandAborted := FALSE;

                    CASE oldCmd OF
                        AxisCmd.MoveVelocity : internalStatus := AxisInternalStatus.MoveVelocityState;
                        AxisCmd.MoveAbsolute : internalStatus := AxisInternalStatus.MoveAbsoluteState;
                        AxisCmd.MoveRelative : internalStatus := AxisInternalStatus.MoveRelativeState;
                        AxisCmd.MoveAdditive : internalStatus := AxisInternalStatus.MoveAdditiveState;
                        AxisCmd.MoveSuperimposed : internalStatus := AxisInternalStatus.MoveSuperimposedState;
                        AxisCmd.Halt : internalStatus := AxisInternalStatus.HaltState;
                        AxisCmd.GearIn : internalStatus := AxisInternalStatus.GearInState;
                        AxisCmd.GearInPos : internalStatus := AxisInternalStatus.GearInPosState;
                        AxisCmd.CamIn : internalStatus := AxisInternalStatus.CamInState;
                        AxisCmd.Phasing : internalStatus := AxisInternalStatus.PhasingState;
                        AxisCmd.SetPosition : internalStatus := AxisInternalStatus.SetPositionState;
                        AxisCmd.PositionProfile : internalStatus := AxisInternalStatus.PositionProfileState;
                        AxisCmd.VelocityProfile : internalStatus := AxisInternalStatus.VelocityProfileState;
                        AxisCmd.AccelerationProfile: internalStatus := AxisInternalStatus.AccelerationProfileState;
                    ELSE
						internalStatus := AxisInternalStatus.Ready;
                    END_CASE;
                ELSE
                    commandExecuted := TRUE;
                    internalStatus := AxisInternalStatus.Ready;
                END_IF;
            END_IF;
            IF cmd <> oldCmd THEN
                IF bufferMode = SM3_Basic.MC_BUFFER_MODE.aborting OR hasPending THEN
                    velProfileExecute := FALSE;
                    IF hasPending THEN
                        CASE pendingCmd OF
                            AxisCmd.MoveVelocity : moveVelocityExecute := FALSE;
                            AxisCmd.MoveAbsolute : moveAbsoluteExecute := FALSE;
                            AxisCmd.MoveRelative : moveRelativeExecute := FALSE;
                            AxisCmd.MoveAdditive : moveAdditiveExecute := FALSE;
                            AxisCmd.MoveSuperimposed : moveSuperimposedExecute := FALSE;
                            AxisCmd.Halt : haltExecute := FALSE;
                            AxisCmd.GearIn : gearInExecute := FALSE;
                            AxisCmd.GearInPos : gearInPosExecute := FALSE;
                            AxisCmd.CamIn : camInExecute := FALSE;
                            AxisCmd.Phasing : phasingExecute := FALSE;
                            AxisCmd.SetPosition : setPositionExecute := FALSE;
                            AxisCmd.PositionProfile : posProfileExecute := FALSE;
                            AxisCmd.VelocityProfile : velProfileExecute := FALSE;
                            AxisCmd.AccelerationProfile: accProfileExecute := FALSE;
                        END_CASE;

                        hasPending := FALSE;
                    END_IF;

                    commandAborted := TRUE;
                    internalStatus := AxisInternalStatus.Ready;
                ELSE
                    pendingCmd := cmd;
                    pendingOldPosition := position; pendingOldDistance := distance; pendingOldVelocity := velocity;
                    pendingOldRatioNumerator := ratioNumerator; pendingOldRatioDenominator := ratioDenominator;
                    pendingOldCamVersion := camVersion; pendingOldStartMode := startMode;
                    pendingOldMasterOffset := masterOffset; pendingOldSlaveOffset := slaveOffset;
                    hasPending := TRUE;
                    oldCmd := pendingCmd;

                    CASE pendingCmd OF
                        AxisCmd.MoveVelocity : moveVelocityExecute := TRUE;
                        AxisCmd.MoveAbsolute : moveAbsoluteExecute := TRUE;
                        AxisCmd.MoveRelative : moveRelativeExecute := TRUE;
                        AxisCmd.MoveAdditive : moveAdditiveExecute := TRUE;
                        AxisCmd.MoveSuperimposed : moveSuperimposedExecute := TRUE;
                        AxisCmd.Halt : haltExecute := TRUE;
                        AxisCmd.GearIn : gearInExecute := TRUE;
                        AxisCmd.GearInPos : gearInPosExecute := TRUE;
                        AxisCmd.CamIn : camInExecute := TRUE;
                        AxisCmd.Phasing : phasingExecute := TRUE;
                        AxisCmd.SetPosition : setPositionExecute := TRUE;
                        AxisCmd.PositionProfile : posProfileExecute := TRUE;
                        AxisCmd.VelocityProfile : velProfileExecute := TRUE;
                        AxisCmd.AccelerationProfile: accProfileExecute := TRUE;
                    ELSE
						hasPending := FALSE;
						commandAborted := TRUE;
						internalStatus := AxisInternalStatus.Ready;
                    END_CASE;
                END_IF;
            END_IF;

        (* AccelerationProfile *)
        AxisInternalStatus.AccelerationProfileState :
            IF mcAccProfile.Done THEN
                accProfileExecute := FALSE;
                IF hasPending THEN
                    hasPending := FALSE;
                    oldPosition := pendingOldPosition; oldDistance := pendingOldDistance; oldVelocity := pendingOldVelocity;
                    oldRatioNumerator := pendingOldRatioNumerator; oldRatioDenominator := pendingOldRatioDenominator;
                    oldCamVersion := pendingOldCamVersion; oldStartMode := pendingOldStartMode;
                    oldMasterOffset := pendingOldMasterOffset; oldSlaveOffset := pendingOldSlaveOffset;
                    commandExecuted := FALSE; commandAborted := FALSE;

                    CASE oldCmd OF
                        AxisCmd.MoveVelocity : internalStatus := AxisInternalStatus.MoveVelocityState;
                        AxisCmd.MoveAbsolute : internalStatus := AxisInternalStatus.MoveAbsoluteState;
                        AxisCmd.MoveRelative : internalStatus := AxisInternalStatus.MoveRelativeState;
                        AxisCmd.MoveAdditive : internalStatus := AxisInternalStatus.MoveAdditiveState;
                        AxisCmd.MoveSuperimposed : internalStatus := AxisInternalStatus.MoveSuperimposedState;
                        AxisCmd.Halt : internalStatus := AxisInternalStatus.HaltState;
                        AxisCmd.GearIn : internalStatus := AxisInternalStatus.GearInState;
                        AxisCmd.GearInPos : internalStatus := AxisInternalStatus.GearInPosState;
                        AxisCmd.CamIn : internalStatus := AxisInternalStatus.CamInState;
                        AxisCmd.Phasing : internalStatus := AxisInternalStatus.PhasingState;
                        AxisCmd.SetPosition : internalStatus := AxisInternalStatus.SetPositionState;
                        AxisCmd.PositionProfile : internalStatus := AxisInternalStatus.PositionProfileState;
                        AxisCmd.VelocityProfile : internalStatus := AxisInternalStatus.VelocityProfileState;
                        AxisCmd.AccelerationProfile: internalStatus := AxisInternalStatus.AccelerationProfileState;
                    ELSE
						internalStatus := AxisInternalStatus.Ready;
                    END_CASE;
                ELSE
                    commandExecuted := TRUE;
                    internalStatus := AxisInternalStatus.Ready;
                END_IF;
            END_IF;
            IF cmd <> oldCmd THEN
                IF bufferMode = SM3_Basic.MC_BUFFER_MODE.aborting OR hasPending THEN
                    accProfileExecute := FALSE;
                    IF hasPending THEN
                        CASE pendingCmd OF
                            AxisCmd.MoveVelocity : moveVelocityExecute := FALSE;
                            AxisCmd.MoveAbsolute : moveAbsoluteExecute := FALSE;
                            AxisCmd.MoveRelative : moveRelativeExecute := FALSE;
                            AxisCmd.MoveAdditive : moveAdditiveExecute := FALSE;
                            AxisCmd.MoveSuperimposed : moveSuperimposedExecute := FALSE;
                            AxisCmd.Halt : haltExecute := FALSE;
                            AxisCmd.GearIn : gearInExecute := FALSE;
                            AxisCmd.GearInPos : gearInPosExecute := FALSE;
                            AxisCmd.CamIn : camInExecute := FALSE;
                            AxisCmd.Phasing : phasingExecute := FALSE;
                            AxisCmd.SetPosition : setPositionExecute := FALSE;
                            AxisCmd.PositionProfile : posProfileExecute := FALSE;
                            AxisCmd.VelocityProfile : velProfileExecute := FALSE;
                            AxisCmd.AccelerationProfile: accProfileExecute := FALSE;
                        END_CASE;

                        hasPending := FALSE;
                    END_IF;

                    commandAborted := TRUE;
                    internalStatus := AxisInternalStatus.Ready;
                ELSE
                    pendingCmd := cmd;
                    pendingOldPosition := position; pendingOldDistance := distance; pendingOldVelocity := velocity;
                    pendingOldRatioNumerator := ratioNumerator; pendingOldRatioDenominator := ratioDenominator;
                    pendingOldCamVersion := camVersion; pendingOldStartMode := startMode;
                    pendingOldMasterOffset := masterOffset; pendingOldSlaveOffset := slaveOffset;
                    hasPending := TRUE;
                    oldCmd := pendingCmd;

                    CASE pendingCmd OF
                        AxisCmd.MoveVelocity : moveVelocityExecute := TRUE;
                        AxisCmd.MoveAbsolute : moveAbsoluteExecute := TRUE;
                        AxisCmd.MoveRelative : moveRelativeExecute := TRUE;
                        AxisCmd.MoveAdditive : moveAdditiveExecute := TRUE;
                        AxisCmd.MoveSuperimposed : moveSuperimposedExecute := TRUE;
                        AxisCmd.Halt : haltExecute := TRUE;
                        AxisCmd.GearIn : gearInExecute := TRUE;
                        AxisCmd.GearInPos : gearInPosExecute := TRUE;
                        AxisCmd.CamIn : camInExecute := TRUE;
                        AxisCmd.Phasing : phasingExecute := TRUE;
                        AxisCmd.SetPosition : setPositionExecute := TRUE;
                        AxisCmd.PositionProfile : posProfileExecute := TRUE;
                        AxisCmd.VelocityProfile : velProfileExecute := TRUE;
                        AxisCmd.AccelerationProfile: accProfileExecute := TRUE;
                    ELSE
						hasPending := FALSE;
						commandAborted := TRUE;
						internalStatus := AxisInternalStatus.Ready;
                    END_CASE;
                END_IF;
            END_IF;

        (* ReadParameter *)
        AxisInternalStatus.ReadParameterState :
            IF readParameter.Valid THEN
                readParameterExecute := FALSE;
                parameterReadValue := readParameter.Value;
                commandExecuted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;
            IF cmd <> oldCmd THEN
                readParameterExecute := FALSE;
                commandAborted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;

        (* WriteParameter *)
        AxisInternalStatus.WriteParameterState :
            IF writeParameter.Done THEN
                writeParameterExecute := FALSE;
                commandExecuted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;
            IF cmd <> oldCmd THEN
                writeParameterExecute := FALSE;
                commandAborted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;

        (* ReadBoolParameter *)
        AxisInternalStatus.ReadBoolParameterState :
            IF readBoolParameter.Valid THEN
                readBoolParameterExecute := FALSE;
                parameterBoolRead := readBoolParameter.Value;
                commandExecuted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;
            IF cmd <> oldCmd THEN
                readBoolParameterExecute := FALSE;
                commandAborted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;

        (* WriteBoolParameter *)
        AxisInternalStatus.WriteBoolParameterState :
            IF writeBoolParameter.Done THEN
                writeBoolParameterExecute := FALSE;
                commandExecuted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;
            IF cmd <> oldCmd THEN
                writeBoolParameterExecute := FALSE;
                commandAborted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;

        (* TouchProbe - capture axis position on hardware trigger *)
        AxisInternalStatus.TouchProbeState :
            IF touchProbe.Done THEN
                touchProbeExecute := FALSE;
                touchProbeValue := touchProbe.RecordedPosition;
                commandExecuted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;
            IF cmd <> oldCmd THEN
                touchProbeExecute := FALSE;
                commandAborted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;

        (* AbortTrigger - cancel any pending touch probe *)
        AxisInternalStatus.AbortTriggerState :
            IF abortTrigger.Done THEN
                abortTriggerExecute := FALSE;
                commandExecuted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;
            IF cmd <> oldCmd THEN
                abortTriggerExecute := FALSE;
                commandAborted := TRUE;
                internalStatus := AxisInternalStatus.Ready;
            END_IF;
    END_CASE;

END_IF; (* End error-recovery guard *)


(*
 * Status Handler - level-triggered, unconditional, every cycle
 *)
readActualPosition(
    Axis := slave,
    Enable := TRUE
);
actualPosition := readActualPosition.Position;

readActualVelocity(
    Axis := slave,
    Enable := TRUE
);
actualVelocity := readActualVelocity.Velocity;

readActualTorque(
    Axis := slave,
    Enable := TRUE
);
actualTorque := readActualTorque.Torque;

readAxisError(
    Axis := slave,
    Enable := TRUE
);
axisErrorId := readAxisError.AxisErrorID;

readStatus(
    Axis := slave,
    Enable := TRUE
);
(* Priority order matches PLCopen FSM: ErrorStop > Disabled > Stopping > Homing > motion states > Standstill *)
IF readStatus.ErrorStop THEN
    status := AxisStatus.ErrorStop;
ELSIF readStatus.Disabled THEN
    status := AxisStatus.Disabled;
ELSIF readStatus.Stopping THEN
    status := AxisStatus.Stopping;
ELSIF readStatus.Homing THEN
    status := AxisStatus.Homing;
ELSIF readStatus.SynchronizedMotion THEN
    status := AxisStatus.SynchronizedMotion;
ELSIF readStatus.ContinuousMotion THEN
    status := AxisStatus.ContinuousMotion;
ELSIF readStatus.DiscreteMotion THEN
    status := AxisStatus.DiscreteMotion;
ELSIF readStatus.Standstill THEN
    status := AxisStatus.Standstill;
ELSE
    status := AxisStatus.Standstill; (* Fallback - consider adding Unknown to AxisStatus DUT *)
END_IF;


(*
 * PLCopen FB calls - unconditional every PLC cycle.
 * Execute / Enable signals are generated exclusively by the FSM above.
 * All motion parameters come directly from VAR_INPUT each cycle.
 *)

(* Administrative / Configuration *)
power(
    Axis := slave,
    Enable := powerEnable,
    bRegulatorOn := powerEnable,
    bDriveStart := powerEnable
);

resetCmd(
    Axis := slave,
    Execute := resetCmdExecute
);

setPosition(
    Axis := slave,
    Execute := setPositionExecute,
    Position := position,
    Mode := setPositionMode
);

(* Homing *)
home(
    Axis := slave,
    Execute := homeExecute,
    Position := homePosition
);

(* Motion *)
moveVelocity(
    Axis := slave,
    Execute := moveVelocityExecute,
    Velocity := velocity,
    Acceleration := acceleration,
    Deceleration := deceleration,
    Jerk := jerk,
    Direction := direction,
    BufferMode := bufferMode
);

moveAbsolute(
    Axis := slave,
    Execute := moveAbsoluteExecute,
    Position := position,
    Velocity := velocity,
    Acceleration := acceleration,
    Deceleration := deceleration,
    Jerk := jerk,
    Direction := direction,
    BufferMode := bufferMode
);

moveRelative(
    Axis := slave,
    Execute := moveRelativeExecute,
    Distance := distance,
    Velocity := velocity,
    Acceleration := acceleration,
    Deceleration := deceleration,
    Jerk := jerk,
    BufferMode := bufferMode
);

moveAdditive(
    Axis := slave,
    Execute := moveAdditiveExecute,
    Distance := distance,
    Velocity := velocity,
    Acceleration := acceleration,
    Deceleration := deceleration,
    Jerk := jerk
);

moveSuperimposed(
    Axis := slave,
    Execute := moveSuperimposedExecute,
    Distance := distance,
    VelocityDiff := velocityDiff,
    Acceleration := acceleration,
    Deceleration := deceleration,
    Jerk := jerk
);

halt(
    Axis := slave,
    Execute := haltExecute,
    Deceleration := deceleration,
    Jerk := jerk
);

haltSuperimposed(
    Axis := slave,
    Execute := haltSuperimposedExecute,
    Deceleration := deceleration,
    Jerk := jerk
);

stop(
    Axis := slave,
    Execute := stopExecute,
    Deceleration := deceleration,
    Jerk := jerk
);

jog(
    Axis := slave,
    JogForward := jogForward AND (internalStatus = AxisInternalStatus.JogState),
    JogBackward := jogBackward AND (internalStatus = AxisInternalStatus.JogState),
    Velocity := velocity,
    Acceleration := acceleration,
    Deceleration := deceleration,
    Jerk := jerk
);

(* Override *)
setOverride(
    Axis := slave,
    Enable := overrideEnable,
    VelFactor := velFactor,
    AccFactor := accFactor,
    JerkFactor := jerkFactor
);

(* Synchronization - master reference required *)
IF __ISVALIDREF(master) THEN
    gearIn(
        Master := master,
        Slave := slave,
        Execute := gearInExecute,
        RatioNumerator := ratioNumerator,
        RatioDenominator := TO_UDINT(ratioDenominator),
        Acceleration := acceleration,
        Deceleration := deceleration,
        Jerk := jerk,
        BufferMode := bufferMode
    );
    gearInPos(
        Master := master,
        Slave := slave,
        Execute := gearInPosExecute,
        RatioNumerator := ratioNumerator,
        RatioDenominator := ratioDenominator,
        MasterSyncPosition := masterSyncPos,
        SlaveSyncPosition := slaveSyncPos
    );
    camIn(
        Master := master,
        Slave := slave,
        Execute := camInExecute,
        CamTableID := camId,
        StartMode := startMode,
        MasterOffset := masterOffset,
        SlaveOffset := slaveOffset,
        BufferMode := bufferMode
    );
    phasing(
        Master := master,
        Slave := slave,
        Execute := phasingExecute,
        PhaseShift := phaseShift,
        Velocity := velocity,
        Acceleration := acceleration,
        Deceleration := deceleration,
        Jerk := jerk
    );
END_IF

gearOut(
    Slave := slave,
    Execute := gearOutExecute
);

camOut(
    Slave := slave,
    Execute := camOutExecute
);

(* Profiles *)
IF __ISVALIDREF(positionProfile) THEN
    mcPositionProfile(
        Axis := slave,
        Execute := posProfileExecute,
        TimePosition := positionProfile
    );
END_IF

IF __ISVALIDREF(velocityProfile) THEN
    mcVelocityProfile(
        Axis := slave,
        Execute := velProfileExecute,
        TimeVelocity := velocityProfile
    );
END_IF

IF __ISVALIDREF(accelerationProfile) THEN
    mcAccProfile(
        Axis := slave,
        Execute := accProfileExecute,
        TimeAcceleration := accelerationProfile
    );
END_IF

(* Parameter access *)
readParameter(
    Axis := slave,
    Enable := readParameterExecute,
    ParameterNumber := parameterNumber
);

writeParameter(
    Axis := slave,
    Execute := writeParameterExecute,
    ParameterNumber := parameterNumber,
    Value := parameterValue
);

readBoolParameter(
    Axis := slave,
    Enable := readBoolParameterExecute,
    ParameterNumber := parameterNumber
);

writeBoolParameter(
    Axis := slave,
    Execute := writeBoolParameterExecute,
    ParameterNumber := parameterNumber,
    Value := parameterBoolValue
);

(* Additional services - triggerInput reference required *)
IF __ISVALIDREF(triggerInput) THEN
    touchProbe(
        Axis := slave,
        Execute := touchProbeExecute,
        TriggerInput := triggerInput,
        WindowOnly := touchProbeWindow,
        FirstPosition := touchProbeFirst,
        LastPosition := touchProbeLast
    );
    abortTrigger(
        Axis := slave,
        Execute := abortTriggerExecute,
        TriggerInput := triggerInput
    );
END_IF
