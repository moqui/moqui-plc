

(*#-#-#-#-#-#-#-#-#-#---Declaration---#-#-#-#-#-#-#-#-#-#-#-#-#*)

TYPE LogEvent : STRUCT
	(* Unique identifier for the log event *)
    logEventId : STRING;
    loggerName : STRING;
	marker : LogMarker;
    level : LogLevel;
    logEventDate : DATE_AND_TIME;
	source : STRING;
	payloadType : LogPayloadType;
    payload : LogPayload;
	(* contextData: STRING; *)
	(* Number of times this log event was repeated, for compression *)
    repeatCount : UINT;
END_STRUCT END_TYPE
